# Copy to .env and adjust. All variables are optional.

# Absolute path to your host's .android directory (contains adbkey + adbkey.pub).
# Empty -> ${HOME}/.android
ADB_KEY_DIR=

# Seconds between screenshot/OCR polls. Low enough to catch a CLAIM before
# it times out.
POLL_INTERVAL=10

# Comma-separated button labels to look for, priority order.
# CLAIM = gem drops; RETRY = reload a finished run.
TARGETS=claim,retry

# Tesseract confidence threshold (0-100).
MIN_CONFIDENCE=80

# Upscale factor applied to the screenshot before OCR. Higher = slower but
# better at reading The Tower's stylized font.
SCALE=3

# Docker network to attach to — must be the same one droidctrl is on.
# Default matches the compose-managed network created by droidctrl.
NETWORK=droidctrl_default
