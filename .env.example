# Copy to .env and adjust. All variables are optional.

# Absolute path to your host's .android directory (contains adbkey + adbkey.pub).
# Empty -> ${HOME}/.android
ADB_KEY_DIR=

# Seconds between screenshot/detect polls. Each tick checks the orbiting
# gem and CLAIM. Low enough to catch a gem/CLAIM before it times out.
POLL_INTERVAL=10

# Seconds between checks for the RETRY button (at most one OCR call per
# RETRY_INTERVAL). Only appears on run death so it doesn't need to be hot.
RETRY_INTERVAL=300

# Seconds to wait after the RETRY button is first detected before clicking it.
# The first detection just starts the timer (and fires the webhook if set).
RETRY_WAIT=180

# Discord webhook URL. If set, a screenshot is posted when the retry screen
# is first detected (i.e. when the wait timer starts).
RETRY_WEBHOOK=

# Message sent with the screenshot. Supports {wait} (seconds from RETRY_WAIT).
# Default: "Run ended — retry pending (waiting {wait}s)."
RETRY_WEBHOOK_MESSAGE=

# Avatar URL used for the webhook post.
# Default: https://raw.githubusercontent.com/crognlie/droidctrl/main/favicons/novnc-64x64.png
RETRY_WEBHOOK_AVATAR=

# Tesseract confidence threshold (0-100) for CLAIM/RETRY.
MIN_CONFIDENCE=80

# Upscale factor applied to the screenshot before OCR. Higher = slower but
# better at reading The Tower's stylized font.
SCALE=3

# Gem detector: score threshold (0-1) for a candidate to be tapped.
GEM_MIN_SCORE=0.70

# Gem detector: orbit-radius band in pixels on a 1080x2400 frame. Rejects
# stationary reward boxes and other off-orbit magenta sprites.
GEM_RADIUS_MIN=280
GEM_RADIUS_MAX=360

# Gem orbit period (seconds) — used for predicting where the gem will be
# when the tap lands. Measure by timing a full revolution.
GEM_PERIOD=12.0

# Measured pipeline latency (seconds) from image capture to tap landing.
# Dominated by `adb screencap` (~800ms raw). Predicting the gem's orbital
# position this far forward is what makes the tap actually land on the gem.
PIPELINE_LATENCY=0.9

# Docker network to attach to — must be the same one droidctrl is on.
# Default matches the compose-managed network created by droidctrl.
NETWORK=droidctrl_default
